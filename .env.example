# Copy to .env for local runs (optional). GitHub Actions should use repository secrets.

# OpenAI (required for narrative digest; omit to use fallback placeholders)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pipeline
DC_PULSE_DRY_RUN=0
DC_PULSE_LOG_LEVEL=INFO
DC_PULSE_LOOKBACK_DAYS=14
DC_PULSE_MAX_TOPICS=7
DC_PULSE_HIGHLIGHT_REPOST=3
# Week-to-week: avoid reusing primary article URLs within a rolling ISO-week window (0 disables blocking)
DC_PULSE_USAGE_HISTORY=1
DC_PULSE_USAGE_HISTORY_WEEKS=12
# Optional absolute path; default is <DC_PULSE_DATA_DIR>/weekly_usage.json
# DC_PULSE_USAGE_HISTORY_PATH=

DC_PULSE_SKIP_LLM=0
DC_PULSE_LLM_TIMEOUT=120

# Multi-phase LLM (defaults: deep research on; article drafts on; web search off)
DC_PULSE_DEEP_RESEARCH=1
DC_PULSE_DEEP_RESEARCH_MODEL=
DC_PULSE_ARTICLE_DRAFTS=1
DC_PULSE_ARTICLE_DRAFT_COUNT=2
DC_PULSE_ARTICLE_DRAFT_WORDS=900
DC_PULSE_ARTICLE_DRAFT_TIMEOUT=300
DC_PULSE_ARTICLE_DRAFT_MODEL=

# Web search (optional — OPENAI_API_KEY for planner + Responses API web_search tool)
DC_PULSE_WEB_SEARCH=0
DC_PULSE_WEB_SEARCH_MODEL=gpt-4o
DC_PULSE_SEARCH_PLANNER_MODEL=
DC_PULSE_SEARCH_MAX_QUERIES=5
DC_PULSE_SEARCH_RESULTS_PER_QUERY=5

# Email (optional; dry-run or missing config skips send)
# Multiple recipients: comma- or semicolon-separated on one line (spaces OK)
DC_PULSE_EMAIL_TO=you@example.com, colleague@example.com
DC_PULSE_EMAIL_FROM=dc-pulse@example.com
DC_PULSE_SMTP_HOST=smtp.example.com
DC_PULSE_SMTP_PORT=587
DC_PULSE_SMTP_USER=
DC_PULSE_SMTP_PASSWORD=
DC_PULSE_SMTP_TLS=1
# Implicit SSL (SMTPS). Default: on when DC_PULSE_SMTP_PORT=465; set to 0 to force STARTTLS-style on 465 if needed.
# DC_PULSE_SMTP_SSL=
DC_PULSE_EMAIL_SUBJECT_PREFIX=DC Pulse Weekly
